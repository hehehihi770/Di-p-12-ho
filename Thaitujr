    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-110,1,0) lbl.Position = UDim2.new(0,26,0,0)
    lbl.BackgroundTransparency = 1 lbl.Text = icon.."  "..label
    lbl.TextColor3 = Color3.fromRGB(225,225,225) lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 14 lbl.TextXAlignment = Enum.TextXAlignment.Left lbl.Parent = btn

    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0,50,0,26) pill.Position = UDim2.new(1,-60,0.5,-13)
    pill.BackgroundColor3 = state[key] and Color3.fromRGB(200,30,30) or Color3.fromRGB(45,45,55)
    pill.BorderSizePixel = 0 pill.Parent = btn
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1,0)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0,20,0,20)
    dot.Position = state[key] and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)
    dot.BackgroundColor3 = Color3.fromRGB(255,255,255) dot.BorderSizePixel = 0 dot.Parent = pill
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)

    btn.MouseButton1Click:Connect(function()
        state[key] = not state[key]
        local on = state[key]
        local tw = TweenInfo.new(0.2, Enum.EasingStyle.Quart)
        TweenService:Create(pill,    tw, {BackgroundColor3 = on and Color3.fromRGB(200,30,30) or Color3.fromRGB(45,45,55)}):Play()
        TweenService:Create(dot,     tw, {Position = on and UDim2.new(1,-23,0.5,-10) or UDim2.new(0,3,0.5,-10)}):Play()
        TweenService:Create(bar,     tw, {BackgroundColor3 = on and Color3.fromRGB(220,40,40) or Color3.fromRGB(60,60,70)}):Play()
        TweenService:Create(bStroke, tw, {Color = on and Color3.fromRGB(220,40,40) or Color3.fromRGB(50,50,60)}):Play()
        if cb then cb(on) end
    end)

    tY = tY + 58
end

