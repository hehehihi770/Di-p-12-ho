    local bStroke = Instance.new("UIStroke")
    bStroke.Color = state[key] and Color3.fromRGB(220,40,40) or Color3.fromRGB(50,50,60)
    bStroke.Thickness = 1.5 bStroke.Parent = btn

    local bar = Instance.new("Frame")
